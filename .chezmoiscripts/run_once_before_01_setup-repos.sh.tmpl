#!/usr/bin/env bash

set -euo pipefail

# ═════════════════════════════════════════════════
# Helpers
# ═════════════════════════════════════════════════

log() { echo "  [repos] $*"; }
ok() { echo "  [repos] ✓ $*"; }
skip() { echo "  [repos] · $* (skipped)"; }

copr_enabled() { dnf copr list --enabled 2>/dev/null | grep -qF "$1"; }
repo_enabled()  { dnf repolist --enabled 2>/dev/null | grep -qF "$1"; }

echo ""
echo "══════════════════════════════════════════════"
echo "  Bootstrapping repositories"
echo "══════════════════════════════════════════════"

# ═════════════════════════════════════════════════
# COPR repositories
# ═════════════════════════════════════════════════

echo ""
echo "-- COPR repositories -"

{{ range .repositories.dnf.copr.repos -}}
if copr_enabled {{ . | quote }}; then
  skip {{ . | quote }}
else
  log "Enabling {{ . }}..."
  sudo dnf copr enable -y {{ . | quote }}
  ok {{ . | quote }}
fi

{{ end -}}

# ═════════════════════════════════════════════════
# RPM Fusion
# ═════════════════════════════════════════════════

echo ""
echo "-- RPM Fusion repositories --"

FEDORA_VER=$(rpm -E %fedora)

if repo_enabled "rpmfusion-free"; then
  skip "rpmfusion-free"
else
  log "Adding RPM Fusion Free..."
  sudo dnf install -y \
    "https://mirrors.rpmfusion.org/free/fedora/rpmfusion-free-release-${FEDORA_VER}.noarch.rpm"
  ok "rpmfusion-free"
fi

if repo_enabled "rpmfusion-nonfree"; then
  skip "rpmfusion-nonfree"
else
  log "Adding RPM Fusion Non-Free..."
  sudo dnf install -y \
    "https://mirrors.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-${FEDORA_VER}.noarch.rpm"
  ok "rpmfusion-nonfree"
fi

log "Installing AppStream metadata..."
sudo dnf install -y rpmfusion-free-appstream-data rpmfusion-nonfree-appstream-data

log "Checking for updates..."
sudo dnf check-update || true   # exits 100 when updates are available — that's fine

log "Updating system..."
sudo dnf update -y
ok "System updated"

# ═════════════════════════════════════════════════
# Docker CE repository
# ═════════════════════════════════════════════════

{{ if .features.containers -}}
echo ""
echo "-- Docker CE repository --"

if repo_enabled "docker-ce-stable"; then
  skip "docker-ce-stable"
else
  log "Adding Docker CE repo..."
  sudo dnf config-manager addrepo \
    --from-repofile=https://download.docker.com/linux/fedora/docker-ce.repo
  ok "docker-ce-stable"
fi
{{ end -}}

# ═════════════════════════════════════════════════
# Flatpak
# ═════════════════════════════════════════════════

echo ""
echo "-- Flatpak remotes --"

if flatpak remotes --system 2>/dev/null | grep -q "^fedora"; then
  log "Removing Fedora SYSTEM remote..."
  sudo flatpak remote-delete --system fedora
fi
if flatpak remotes --user 2>/dev/null | grep -q "^fedora"; then
  log "Removing Fedora USER remote..."
  flatpak remote-delete --user fedora
fi

if flatpak remotes --system 2>/dev/null | grep -q "^flathub"; then
  skip "Flathub SYSTEM remote"
else
  log "Adding Flathub SYSTEM remote..."
  sudo flatpak remote-add --if-not-exists --system flathub https://dl.flathub.org/repo/flathub.flatpakrepo
  ok "Flathub SYSTEM added"
fi

if flatpak remotes --user 2>/dev/null | grep -q "^flathub"; then
  skip "Flathub USER remote"
else
  log "Adding Flathub USER remote..."
  flatpak remote-add --if-not-exists --user flathub  https://dl.flathub.org/repo/flathub.flatpakrepo
  ok "Flathub USER added"
fi

echo ""
echo "  Repositories configured."
echo ""
