// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "existing_window",
  "outline_panel": {
    "dock": "left",
  },
  "active_pane_modifiers": {},
  "window_decorations": "server",
  "status_bar": {
    "show_active_file": false,
  },
  "show_edit_predictions": true,
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "languages": {
    "Rust": {
      "show_edit_predictions": true,
    },
    "TypeScript": {
      "format_on_save": "on",
    },
    "HTML": {
      "format_on_save": "off",
    },
    "C": {
      "format_on_save": "on",
    },
  },
  "git": {
    "inline_blame": {
      "show_commit_summary": false,
    },
    "path_style": "file_name_first",
    "hunk_style": "staged_hollow",
    "blame": {
      "show_avatar": true,
    },
  },
  "buffer_font_family": ".ZedMono",
  "preview_tabs": {
    "enabled": true,
  },
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": false,
    "show_tab_bar_buttons": true,
    "show_nav_history_buttons": false,
  },
  "current_line_highlight": "all",
  "text_rendering_mode": "platform_default",
  "agent_ui_font_size": 16.0,
  "buffer_line_height": "comfortable",
  "icon_theme": {
    "mode": "system",
    "light": "Colored Zed Icons Theme Light",
    "dark": "Colored Zed Icons Theme Dark",
  },
  "collaboration_panel": {
    "dock": "left",
    "button": false,
  },
  "colorize_brackets": true,
  "lsp_document_colors": "inlay",
  "inlay_hints": {
    "enabled": false,
    "show_background": false,
  },
  "auto_install_extensions": {
    "catppuccin-blur": true,
    "comment": true,
    "git-firefly": true,
    "log": true,
    "mcp-server-sequential-thinking": true,
    "toml": true,
    "colored-zed-icons-theme": true,
    "dockerfile": true,
    "html": true,
    "make": true,
    "neocmake": true,
  },
  "show_wrap_guides": true,
  "indent_guides": {
    "background_coloring": "disabled",
    "enabled": true,
  },
  "soft_wrap": "none",
  "toolbar": {
    "agent_review": true,
    "selections_menu": false,
    "quick_actions": false,
    "code_actions": false,
    "breadcrumbs": true,
  },
  "minimap": {
    "show": "never",
  },
  "relative_line_numbers": "disabled",
  "auto_signature_help": false,
  "sticky_scroll": {
    "enabled": false,
  },
  "which_key": {
    "enabled": false,
  },
  "git_panel": {
    "dock": "left",
    "scrollbar": {
      "show": "never",
    },
    "collapse_untracked_diff": false,
    "sort_by_path": false,
    "status_style": "icon",
    "tree_view": true,
  },
  "project_panel": {
    "sticky_scroll": false,
    "scrollbar": {
      "show": "never",
    },
    "sort_mode": "directories_first",
    "default_width": 350.0,
    "entry_spacing": "comfortable",
    "button": true,
    "bold_folder_labels": false,
    "dock": "left",
  },
  "use_system_window_tabs": false,
  "bottom_dock_layout": "contained",
  "tabs": {
    "show_close_button": "hover",
    "file_icons": false,
    "git_status": false,
  },
  "title_bar": {
    "button_layout": "platform_default",
    "show_branch_name": false,
    "show_user_picture": true,
    "show_project_items": true,
    "show_menus": false,
  },
  "wsl_connections": [
    {
      "distro_name": "Ubuntu",
      "user": null,
      "projects": [
        {
          "paths": ["/home/k0oda/projects/alife-sim"],
        },
        {
          "paths": ["/home/k0oda/projects/bevy-game"],
        },
        {
          "paths": ["/home/k0oda/projects/blockscout"],
        },
        {
          "paths": ["/home/k0oda/projects/dj-qevm-landing"],
        },
        {
          "paths": ["/home/k0oda/projects/purc-js"],
        },
        {
          "paths": ["/home/k0oda/projects/qethers"],
        },
        {
          "paths": ["/home/k0oda/projects/qevm-network"],
        },
        {
          "paths": ["/home/k0oda/projects/qhardhat/./"],
        },
        {
          "paths": ["/home/k0oda/projects/qsolidity"],
        },
        {
          "paths": ["/home/k0oda/projects/test-rust"],
        },
      ],
    },
  ],
  "edit_predictions": {
    "allow_data_collection": "no",
    "copilot": {
      "enable_next_edit_suggestions": true,
    },
    "provider": "copilot",
  },
  "prettier": {},
  "agent": {
    "sidebar_side": "right",
    "flexible": false,
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6",
      "enable_thinking": false,
    },
    "tool_permissions": {
      "tools": {
        "fetch": {
          "always_allow": [
            {
              "pattern": "^https?://raw\\.githubusercontent\\.com",
            },
          ],
        },
        "terminal": {
          "always_allow": [
            {
              "pattern": "^cat\\b",
            },
            {
              "pattern": "^node\\b",
            },
            {
              "pattern": "^grep\\b",
            },
            {
              "pattern": "^head\\b",
            },
          ],
        },
      },
    },
    "default_profile": "write",
    "profiles": {},
    "dock": "right",
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "gemini-3.1-pro-preview",
    },
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "claude-opus-4.6",
        "enable_thinking": false,
      },
      {
        "provider": "copilot_chat",
        "model": "claude-sonnet-4.6",
        "enable_thinking": false,
      },
      {
        "provider": "anthropic",
        "model": "claude-sonnet-4-6-latest",
        "enable_thinking": false,
      },
      {
        "provider": "copilot_chat",
        "model": "gemini-3.1-pro-preview",
        "enable_thinking": false,
      },
    ],
    "model_parameters": [],
    "enable_feedback": false,
  },
  "terminal": {
    "default_height": 420.0,
    "toolbar": {
      "breadcrumbs": false,
    },
    "font_size": 14.0,
    "dock": "bottom",
    "keep_selection_on_copy": true,
    "blinking": "on",
    "cursor_shape": "bar",
  },
  "base_keymap": "VSCode",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": false,
  "ui_font_size": 16.0,
  "buffer_font_size": 14.0,
  "buffer_font_features": {
    "calt": true,
  },
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte (Blur)",
    "dark": "Catppuccin Espresso (Blur) [Heavy]",
  },
}
